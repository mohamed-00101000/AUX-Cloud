  <property name="styleSheet">
   <string notr="true">

/* -----------------------------------------------------------
   MAIN WINDOW COLORS
----------------------------------------------------------- */
QMainWindow {
    background: #1a1a1d;       /* ASURT dark gray */
    color: #e8eefc;
}

/* -----------------------------------------------------------
   GROUPBOXES
----------------------------------------------------------- */
QGroupBox {
    border: 1px solid #2b2b2d;
    border-radius: 12px;
    margin-top: 24px;
    padding: 12px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 14px;
    top: 6px;
    color: #bfbfc8;
    font-weight: 600;
}

/* -----------------------------------------------------------
   TABS
----------------------------------------------------------- */
QTabWidget::pane {
    border: 0;
    top: -1px;
}

QTabBar::tab {
    background: #101013;
    color: #bfbfc8;
    padding: 8px 16px;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
    margin-right: 2px;
}

QTabBar::tab:selected {
    background: #2a0f12;      /* Dark red tone */
    color: #ffffff;
    border-bottom: 2px solid #d90429;
}

/* -----------------------------------------------------------
   LABEL STYLING
----------------------------------------------------------- */
QLabel {
    color: #e8eefc;
}

QLabel#titleLabel, QLabel#teamNameLabel {
    font-size: 80px;
    font-weight: 900;
    letter-spacing: 1.2px;
    color: #d6d6d6;

}



/* -----------------------------------------------------------
   COMBOBOX, SPINBOX, LINEEDIT
----------------------------------------------------------- */
QComboBox, QSpinBox, QLineEdit {
    background: #101013;
    border: 1px solid #2b2b2d;
    border-radius: 8px;
    color: #e8eefc;
    padding: 4px 8px;
    min-height: 36px;
}

QComboBox:hover, QSpinBox:hover, QLineEdit:hover {
    border: 1px solid #d90429;
}

/* ================================
   COMBOBOX TEXT (CLOSED STATE)
================================ */
QComboBox#cmbSession {
    min-height: 42px;        /* make it taller */
    padding-left: 10px;
    padding-right: 28px;     /* space for arrow */
}

/* 🔥 THIS controls the visible text */
QComboBox#cmbSession QLineEdit {
    font-size: 20px;         /* BIG TEXT */
    font-weight: 500;
    color: #e8eefc;
    background: transparent;
    border: none;
}

/* ================================
   COMBOBOX DROPDOWN
================================ */
QComboBox#cmbSession QAbstractItemView {
    font-size: 20px;
    padding: 8px;
    background: #101013;
    color: #e8eefc;
    selection-background-color: #2a0f12;
}

/* Arrow stays clean */
QComboBox#cmbSession::down-arrow {
    image: none;
    border: 4px solid #e8eefc;
    border-top-color: transparent;
    border-left-color: transparent;
    border-right-color: transparent;
}



/* -----------------------------------------------------------
   PROGRESS BARS (Battery, Thermal, Electrical)
----------------------------------------------------------- */
QProgressBar {
    border: 1px solid #2b2b2d;
    border-radius: 8px;
    text-align: center;
    height: 20px;
    background: #101013;
    color: #ffffff;
}

QProgressBar::chunk {
    background-color: #d90429;      /* Main ASURT red */
    border-radius: 8px;
}

/* -----------------------------------------------------------
   DARKER RED VARIANTS FOR THERMAL RANGES
----------------------------------------------------------- */
QProgressBar[thermal=&quot;true&quot;]::chunk {
    background-color: #8b0000;
}

QProgressBar[electrical=&quot;true&quot;]::chunk {
    background-color: #d90429;
}

/* -----------------------------------------------------------
   GENERAL FRAMES
----------------------------------------------------------- */
QFrame {
    background: transparent;
}

/* Divider frame */
QFrame#thinDivider {
    background: #2b2b2d;
}

/* -----------------------------------------------------------
   QGRAPHICSVIEW (Track Map)
----------------------------------------------------------- */
QGraphicsView#trackMapView {
    background: #0d1222;
    border: 1px solid #2b3142;
    border-radius: 8px;
}


/* -----------------------------------------------------------
   BUTTONS (if added later)
----------------------------------------------------------- */
QPushButton {
    background: #111114;
    border: 1px solid #2b2b2d;
    border-radius: 6px;
    color: white;
    padding: 6px 12px;
}

QPushButton:hover {
    background: #2a0f12;
    border: 1px solid #d90429;
}

QPushButton:pressed {
    background: #d90429;
}

/* -----------------------------------------------------------
   MEASUREMENT VALUES — Improved Readability (+2pt, clearer)
----------------------------------------------------------- */

/* Main measurement values — speed, voltage, temperature, GPS, battery %, etc. */
/* ===========================================================
   BASE MEASUREMENT LABELS (NON-THERMAL)
=========================================================== */
QLabel.measure {
    font-size: 24px;
    font-weight: 700;
    color: #ffffff;
}

/* ===========================================================
   THERMAL TAB — BASE VALUES
=========================================================== */

/* Sub descriptions remain softer */
QLabel[data-type=&quot;subtext&quot;] {
    font-size: 13px;
    color: #9aa5b8;
}

/* Unit labels (°C, km/h, V, A, W, etc.) */
QLabel[data-type=&quot;unit&quot;] {
    font-size: 16px;
    font-weight: 600;
    color: #d7d7e0;
}

QSpinBox#spinLap {
    background: #101013;
    border: 1px solid #2b2b2d;
    border-radius: 8px;
    color: #e8eefc;
    padding: 4px 8px;
    min-height: 36px;
}

/* 🔥 THIS is what controls the number */
QSpinBox::up-button,
QSpinBox::down-button {
    width: 18px;
}

QSpinBox#spinLap QLineEdit {
    font-size: 20px;
    color: #e8eefc;
    background: transparent;
    border: none;
}

/* ===========================================================
   THERMAL TAB — SCOPED STYLING ONLY
=========================================================== */

QWidget#tabThermal {
    background: transparent;
}

QWidget#tabThermal QGroupBox {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #151922, stop:1 #0f1218);
    border: 1px solid #2a3140;
    border-radius: 14px;
}

QWidget#tabThermal QGroupBox::title {
    color: #7fb3ff;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.6px;
}

QLabel.measure {
    font-size: 22px;
    font-weight: 700;
    color: #ffffff;
}

QWidget#tabThermal QLabel.measure {
    font-size: 26px;
    font-weight: 800;
    color: #eaf1ff;
}

QWidget#tabThermal QLabel.summaryText {
    font-size: 26px;
    font-weight: 600;
    color: #a8b3cf;
}

QWidget#tabThermal QLabel.summaryValue {
    font-size: 36px;
    font-weight: 900;
    color: #5fd1ff;
}
/* ===========================================================
   ELECTRICAL TAB
=========================================================== */

QWidget#tabElectrical {
    background: transparent;
}

QWidget#tabElectrical QGroupBox#grpElectricalOverview {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #151922,
        stop:1 #0f1218
    );
    border: 1px solid #2a3140;
    border-radius: 16px;
    padding: 24px;
}


QGroupBox.elecCard {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #151922,
        stop:1 #0f1218
    );
    border: 1px solid #2a3140;
    border-radius: 14px;
}

QGroupBox.elecCard::title {
    color: #7fb3ff;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.6px;
}

QWidget#tabElectrical QGroupBox::title {
    color: #7fb3ff;
    font-size: 18px;
    font-weight: 800;
    letter-spacing: 1px;
    padding-left: 8px;
}


/* Left text */
QWidget#tabElectrical QLabel.electricalLabel {
    font-size: 22px;
    font-weight: 600;
    color: #a8b3cf;
}


/* Right values */
QWidget#tabElectrical QLabel.electricalValue {
    font-size: 36px;          /* BIG */
    font-weight: 900;
    color: #5fd1ff;
}


/* ===========================================================
   ELECTRICAL TAB — SOC PROGRESS BAR (THICK + LARGE TEXT)
=========================================================== */

QWidget#tabElectrical QProgressBar#progressElecSOC {
    min-height: 36px;            /* FORCE thickness */
    max-height: 36px;
    border-radius: 18px;

    border: 1px solid #2b3142;
    background: #101013;

    color: white;
    font-size: 20px;             /* BIG text inside bar */
    font-weight: 800;
    text-align: center;
}

QWidget#tabElectrical QProgressBar#progressElecSOC::chunk {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 #d90429,
        stop:1 #ff4d6d
    );
    border-radius: 18px;
}


/* ===========================================================
   ELECTRICAL TAB — LARGE DASHBOARD STYLING
=========================================================== */

QWidget#tabElectrical QLabel.electricalLabel {
    font-size: 35px;
    font-weight: 1000;
    color: #a8b3cf;
}

QWidget#tabElectrical QLabel.elecValue {
    font-size: 32px;          /* BIG numbers */
    font-weight: 900;
    color: #5fd1ff;
}

/* Spacing between rows */
QWidget#tabElectrical QGridLayout {
    row-gap: 18px;
}




</string>
