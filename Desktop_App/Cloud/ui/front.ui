  <property name="styleSheet">
   <string notr="true">/* -----------------------------------------------------------
   MAIN WINDOW COLORS
----------------------------------------------------------- */
QMainWindow {
    background: #1a1a1d;       /* ASURT dark gray */
    color: #e8eefc;
}

/* -----------------------------------------------------------
   GROUPBOXES
----------------------------------------------------------- */
QGroupBox {
    border: 1px solid #2b2b2d;
    border-radius: 12px;
    margin-top: 24px;
    padding: 12px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 14px;
    top: 6px;
    color: #bfbfc8;
    font-weight: 600;
}

/* -----------------------------------------------------------
   TABS
----------------------------------------------------------- */
QTabWidget::pane {
    border: 0;
    top: -1px;
}

QTabBar::tab {
    background: #101013;
    color: #bfbfc8;
    padding: 8px 16px;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
    margin-right: 2px;
}

QTabBar::tab:selected {
    background: #2a0f12;      /* Dark red tone */
    color: #ffffff;
    border-bottom: 2px solid #d90429;
}

/* -----------------------------------------------------------
   LABEL STYLING
----------------------------------------------------------- */
QLabel {
    color: #e8eefc;
}

QLabel#titleLabel, QLabel#teamNameLabel {
    font-size: 28px;
    font-weight: 900;
    letter-spacing: 1.2px;
    color: #ffffff;
}

/* -----------------------------------------------------------
   COMBOBOX, SPINBOX, LINEEDIT
----------------------------------------------------------- */
QComboBox, QSpinBox, QLineEdit {
    background: #101013;
    border: 1px solid #2b2b2d;
    border-radius: 8px;
    color: #e8eefc;
    padding: 4px 8px;
}

QComboBox:hover, QSpinBox:hover, QLineEdit:hover {
    border: 1px solid #d90429;
}

QComboBox {
    color: #e8eefc;     /* SAME color as other text */
}

QComboBox QAbstractItemView {
    color: #e8eefc;         /* text color */
    background: #101013;    /* dropdown background */
    selection-background-color: #2a0f12; /* dark red selection */
    selection-color: #ffffff;
}

QComboBox::down-arrow {
    image: none;
    border: 4px solid #e8eefc;
    border-top-color: transparent;
    border-left-color: transparent;
    border-right-color: transparent;
}


/* -----------------------------------------------------------
   PROGRESS BARS (Battery, Thermal, Electrical)
----------------------------------------------------------- */
QProgressBar {
    border: 1px solid #2b2b2d;
    border-radius: 8px;
    text-align: center;
    height: 20px;
    background: #101013;
    color: #ffffff;
}

QProgressBar::chunk {
    background-color: #d90429;      /* Main ASURT red */
    border-radius: 8px;
}

/* -----------------------------------------------------------
   DARKER RED VARIANTS FOR THERMAL RANGES
----------------------------------------------------------- */
QProgressBar[thermal="true"]::chunk {
    background-color: #8b0000;
}

QProgressBar[electrical="true"]::chunk {
    background-color: #d90429;
}

/* -----------------------------------------------------------
   GENERAL FRAMES
----------------------------------------------------------- */
QFrame {
    background: transparent;
}

/* Divider frame */
QFrame#thinDivider {
    background: #2b2b2d;
}

/* -----------------------------------------------------------
   QGRAPHICSVIEW (Track Map)
----------------------------------------------------------- */
QGraphicsView {
    background: #0d0d0f;
    border: 1px solid #2b2b2d;
    border-radius: 8px;
}

/* -----------------------------------------------------------
   BUTTONS (if added later)
----------------------------------------------------------- */
QPushButton {
    background: #111114;
    border: 1px solid #2b2b2d;
    border-radius: 6px;
    color: white;
    padding: 6px 12px;
}

QPushButton:hover {
    background: #2a0f12;
    border: 1px solid #d90429;
}

QPushButton:pressed {
    background: #d90429;
}

/* -----------------------------------------------------------
   MEASUREMENT VALUES — Improved Readability (+2pt, clearer)
----------------------------------------------------------- */

/* Main measurement values — speed, voltage, temperature, GPS, battery %, etc. */
QLabel[data-type="measure"] {
    font-size: 20px;       /* larger and easier to read */
    font-weight: 700;      /* stronger emphasis */
    color: #ffffff;        /* brightest text for numeric values */
}

/* Sub descriptions remain softer */
QLabel[data-type="subtext"] {
    font-size: 13px;
    color: #9aa5b8;
}

/* Spinboxes, comboboxes, and line edits get a +2 readability boost */
QSpinBox, QDoubleSpinBox, QLineEdit, QComboBox {
    font-size: 16px;   /* previously 14px */
}

/* Unit labels (°C, km/h, V, A, W, etc.) */
QLabel[data-type="unit"] {
    font-size: 16px;
    font-weight: 600;
    color: #d7d7e0;
}


</string>
